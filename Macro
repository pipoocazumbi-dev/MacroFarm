local player = game.Players.LocalPlayer
local VirtualInputManager = game:GetService("VirtualInputManager")
local UIS = game:GetService("UserInputService")

-- ===== CONFIG =====
local CHECKPOINT_DELAY = 3
local GLOBAL_TIMEOUT = 30
local START_DELAY_AFTER_KEY = 2

-- ===== CHARACTER =====
local character, humanoid, root

local function getCharacter()
	character = player.Character or player.CharacterAdded:Wait()
	humanoid = character:WaitForChild("Humanoid")
	root = character:WaitForChild("HumanoidRootPart")
end

getCharacter()
player.CharacterAdded:Connect(function()
	task.wait(0.5)
	getCharacter()
end)

-- ===== VARIÁVEIS =====
local checkpoints = {}
local isRunning = false
local currentIndex = 0
local scriptActive = true

-- ===== GUI =====
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0, 260, 0, 240) -- 🔼 aumentado
frame.Position = UDim2.new(1, -270, 0, 20)
frame.BackgroundColor3 = Color3.fromRGB(20,20,20)
frame.Active = true
Instance.new("UICorner", frame)

-- Título
local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1, -40, 0, 30)
title.Position = UDim2.new(0,10,0,5)
title.Text = "Macro System"
title.TextColor3 = Color3.new(1,1,1)
title.BackgroundTransparency = 1
title.Font = Enum.Font.GothamBold
title.TextSize = 14
title.TextXAlignment = Enum.TextXAlignment.Left

-- Fechar
local closeBtn = Instance.new("TextButton", frame)
closeBtn.Size = UDim2.new(0,25,0,25)
closeBtn.Position = UDim2.new(1,-30,0,5)
closeBtn.Text = "X"
closeBtn.BackgroundColor3 = Color3.fromRGB(170,50,50)
closeBtn.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", closeBtn)

-- Status
local statusCircle = Instance.new("Frame", frame)
statusCircle.Size = UDim2.new(0,15,0,15)
statusCircle.Position = UDim2.new(0,10,0,45)
Instance.new("UICorner", statusCircle)

local statusText = Instance.new("TextLabel", frame)
statusText.Size = UDim2.new(1, -30, 0, 20)
statusText.Position = UDim2.new(0,30,0,43)
statusText.BackgroundTransparency = 1
statusText.TextColor3 = Color3.new(1,1,1)

-- Progresso
local checkpointLabel = Instance.new("TextLabel", frame)
checkpointLabel.Size = UDim2.new(1, -20, 0, 20)
checkpointLabel.Position = UDim2.new(0,10,0,70)
checkpointLabel.BackgroundTransparency = 1
checkpointLabel.TextColor3 = Color3.fromRGB(200,200,200)

-- ===== INPUTS =====
local function createInput(labelText, posY, default)
	local label = Instance.new("TextLabel", frame)
	label.Size = UDim2.new(0,80,0,25)
	label.Position = UDim2.new(0,10,0,posY)
	label.Text = labelText
	label.TextColor3 = Color3.new(1,1,1)
	label.BackgroundTransparency = 1
	
	local box = Instance.new("TextBox", frame)
	box.Size = UDim2.new(0,60,0,25)
	box.Position = UDim2.new(0,90,0,posY)
	box.Text = tostring(default)
	box.BackgroundColor3 = Color3.fromRGB(40,40,40)
	box.TextColor3 = Color3.new(1,1,1)
	Instance.new("UICorner", box)
	
	return box
end

local delayBox = createInput("Delay", 110, CHECKPOINT_DELAY)
local limitBox = createInput("Limit", 145, GLOBAL_TIMEOUT)

-- ===== BOTÕES =====
local function createButton(text, x, y)
	local btn = Instance.new("TextButton", frame)
	btn.Size = UDim2.new(0,100,0,30)
	btn.Position = UDim2.new(0,x,0,y)
	btn.Text = text
	btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
	btn.TextColor3 = Color3.new(1,1,1)
	Instance.new("UICorner", btn)
	return btn
end

local startBtn = createButton("Start", 10, 190)
local addBtn = createButton("Add", 120, 190)
local clearBtn = createButton("Clear", 10, 225) -- 🔽 agora separado

-- ===== DRAG =====
local dragging, dragStart, startPos

frame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = frame.Position
		
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart
		frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

-- ===== FUNÇÕES (iguais) =====

local function updateGUI()
	checkpointLabel.Text = "Checkpoint: " .. currentIndex .. "/" .. #checkpoints
	
	if isRunning then
		statusCircle.BackgroundColor3 = Color3.fromRGB(0,255,0)
		statusText.Text = "Ativo"
		startBtn.Text = "Pause"
	else
		statusCircle.BackgroundColor3 = Color3.fromRGB(255,0,0)
		statusText.Text = "Parado"
		startBtn.Text = "Start"
	end
end

local function updateConfig()
	local d = tonumber(delayBox.Text)
	local l = tonumber(limitBox.Text)
	if d then CHECKPOINT_DELAY = d end
	if l then GLOBAL_TIMEOUT = l end
end

delayBox.FocusLost:Connect(updateConfig)
limitBox.FocusLost:Connect(updateConfig)

local function createCheckpoint()
	local part = Instance.new("Part")
	part.Size = Vector3.new(1,1,1)
	part.Anchored = true
	part.CanCollide = false
	part.Color = Color3.fromRGB(0,170,255)
	part.Position = root.Position
	part.Parent = workspace
	table.insert(checkpoints, part)
	updateGUI()
end

local function clearCheckpoints()
	for _, p in ipairs(checkpoints) do
		if p then p:Destroy() end
	end
	checkpoints = {}
	currentIndex = 0
	updateGUI()
end

local function pressKey4()
	VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Four, false, game)
	task.wait(0.1)
	VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Four, false, game)
end

local function moveTo(pos)
	humanoid:MoveTo(pos)
	humanoid.MoveToFinished:Wait()
end

local function runLoop()
	while isRunning and scriptActive do
		if humanoid then humanoid.Health = 0 end
		task.wait(4)
		getCharacter()
		
		pressKey4()
		task.wait(START_DELAY_AFTER_KEY)
		
		local startTime = tick()
		local completed = true
		
		for i, checkpoint in ipairs(checkpoints) do
			if not isRunning or not scriptActive then return end
			
			currentIndex = i
			updateGUI()
			
			if tick() - startTime > GLOBAL_TIMEOUT then
				completed = false
				break
			end
			
			moveTo(checkpoint.Position)
			task.wait(CHECKPOINT_DELAY)
		end
		
		if not completed then
			continue
		end
	end
end

startBtn.MouseButton1Click:Connect(function()
	isRunning = not isRunning
	updateGUI()
	if isRunning then
		updateConfig()
		task.spawn(runLoop)
	end
end)

addBtn.MouseButton1Click:Connect(createCheckpoint)
clearBtn.MouseButton1Click:Connect(clearCheckpoints)

closeBtn.MouseButton1Click:Connect(function()
	isRunning = false
	scriptActive = false
	clearCheckpoints()
	gui:Destroy()
end)

updateGUI()
